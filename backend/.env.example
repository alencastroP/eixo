# ─── Banco de dados ──────────────────────────────────────────────────────────
# Com Docker (docker compose up -d na raiz):
# DATABASE_URL="postgresql://crm:crm@localhost:5432/crm?schema=public"
# Com o Postgres embutido de desenvolvimento (npm run db:dev):
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/crm?schema=public"
# Usada apenas pelo Prisma Migrate (schema/migrations). Em produção com Neon,
# aponte para a connection string SEM "-pooler" (conexão direta). Em dev,
# repita o mesmo valor de DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/crm?schema=public"

# ─── Servidores ──────────────────────────────────────────────────────────────
PORT=3001               # API principal
WEBHOOK_PORT=3002       # Serviço de recepção de webhooks (processo independente)
CORS_ORIGIN=http://localhost:5173

# ─── Autenticação (gere valores fortes em produção) ─────────────────────────
JWT_ACCESS_SECRET=troque-este-segredo
JWT_REFRESH_TTL_DAYS=7
JWT_ACCESS_TTL=15m
# Cifra as credenciais de API das integrações em repouso (AES-256-GCM).
# Em produção use um cofre/KMS; trocar este valor invalida credenciais já salvas.
CREDENTIALS_SECRET=troque-este-segredo-de-credenciais

# ─── Regras de negócio ───────────────────────────────────────────────────────
# Janela de deduplicação: novo contato do mesmo lead na mesma plataforma dentro
# desta janela atualiza o ticket aberto em vez de criar outro.
DEDUP_WINDOW_HOURS=72
# SLA de primeira resposta (minutos) — usado no campo calculado `sla.breached`.
SLA_FIRST_RESPONSE_MINUTES=30

# ─── Worker de processamento de leads ────────────────────────────────────────
WORKER_POLL_INTERVAL_MS=2000
WORKER_BATCH_SIZE=20
WORKER_MAX_ATTEMPTS=5
WORKER_RETRY_DELAY_MS=30000
# O webhook-server inicia o worker no mesmo processo por padrão (conveniente em dev).
# Em produção, rode `npm run start:worker` separado e defina WORKER_INLINE=false.
WORKER_INLINE=true

# ─── Credenciais dos webhooks por plataforma (NUNCA hardcoded no código) ─────
# Sem o valor definido: em dev o webhook é aceito com aviso; em produção é rejeitado.
OLX_WEBHOOK_TOKEN=dev-olx-token
MERCADOLIVRE_WEBHOOK_SECRET=dev-ml-secret
WEBMOTORS_WEBHOOK_TOKEN=dev-webmotors-token

# ─── Agente de Pré-Venda IA (Anthropic Claude) ───────────────────────────────
# Sem a chave, o Co-Piloto fica indisponível e o atendimento segue 100% humano.
ANTHROPIC_API_KEY=
# Modelo. Padrão: claude-opus-4-8 (mais capaz). Para alto volume/menor latência
# e custo, aponte para claude-sonnet-5 ou claude-haiku-4-5.
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOOL_ITERATIONS=4
ANTHROPIC_MAX_TOKENS=1024

# ─── Rate limiting (proteção contra força-bruta / abuso) ─────────────────────
RATE_LIMIT_GLOBAL_PER_MIN=300
RATE_LIMIT_AUTH_PER_15MIN=20
RATE_LIMIT_WEBHOOK_PER_MIN=120

# ─── Retenção de dados (LGPD — expurgo via `npm run purge`) ──────────────────
RETENTION_WEBHOOK_EVENT_DAYS=90
RETENTION_CREDIT_QUERY_DAYS=365
RETENTION_AUDIT_LOG_DAYS=730

# ─── SaaS / Trial ────────────────────────────────────────────────────────────
# Pepper do hash de unicidade de CPF do trial (OBRIGATÓRIO em produção — cofre).
TRIAL_CPF_PEPPER=
# Máx. de cadastros de trial por IP por hora (anti-bot).
RATE_LIMIT_TRIAL_PER_HOUR=5
