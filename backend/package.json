{
  "name": "crm-backend",
  "version": "0.1.0",
  "private": true,
  "description": "CRM Automotivo — API, serviço de webhooks e worker de leads (módulo de Atendimento/Tickets)",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:webhooks": "tsx watch src/webhook-server.ts",
    "dev:worker": "tsx watch src/workers/lead-processor.ts",
    "db:dev": "tsx scripts/dev-db.ts",
    "db:reset-data": "tsx scripts/reset-data.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:webhooks": "node dist/webhook-server.js",
    "start:worker": "node dist/workers/lead-processor.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "purge": "tsx scripts/purge.ts",
    "backfill:accounts": "tsx scripts/backfill-accounts.ts",
    "expire-trials": "tsx scripts/expire-trials.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@prisma/client": "^6.10.0",
    "bcryptjs": "^3.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "embedded-postgres": "^18.4.0-beta.17",
    "prisma": "^6.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
